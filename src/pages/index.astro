---
import '../styles/global.css';

const navLinks = [
	{ href: '#med-arb', label: 'Med-Arb' },
	{ href: '#mediation', label: 'Mediation' },
	{ href: '#arbitration', label: 'Arbitration' },
	{ href: '#about', label: 'About' },
	{ href: '#fees', label: 'Fees' },
	{ href: '#booking', label: 'Booking' },
	{ href: '#contact', label: 'Contact' },
];

const practiceAreas = [
	{
		id: 'med-arb',
		eyebrow: 'New Specialty',
		title: 'Med-Arb',
		intro:
			'A single, seamless process that combines the collaborative strength of mediation with the binding finality of arbitration — guaranteeing a resolution.',
		items: [
			'Begins as a facilitated mediation between the parties',
			'If issues remain unresolved, the same neutral becomes arbitrator',
			'Issues a final, binding decision without separate proceedings',
			'Saves time and cost versus running two distinct processes',
		],
	},
	{
		id: 'mediation',
		eyebrow: 'Core Service',
		title: 'Mediation',
		intro:
			'A confidential, voluntary process that helps parties communicate, identify their real interests, and reach a resolution that works for everyone.',
		items: [
			'Commercial and business disputes',
			'Workplace and employment conflicts',
			'Family and divorce matters',
			'Real estate and property disputes',
			'Construction disputes',
			'Community and neighbour conflicts',
		],
	},
	{
		id: 'arbitration',
		eyebrow: 'Core Service',
		title: 'Arbitration',
		intro:
			'A streamlined alternative to litigation. As a neutral arbitrator, Peter reviews the evidence and arguments and issues a fair, well-reasoned decision.',
		items: [
			'Binding arbitration — a final, enforceable decision',
			'Non-binding arbitration — an expert advisory opinion',
			'Greater speed, privacy, and flexibility than court',
			'Procedure tailored to the scale of the dispute',
		],
	},
];

const approach = [
	{
		heading: 'Clear and direct',
		description:
			'Peter listens, clarifies the issues, and helps parties understand their positions in order to drive a resolution.',
	},
	{
		heading: 'Prepared and thorough',
		description:
			'He works to understand the details of the dispute and the dynamics between the parties before the process begins.',
	},
	{
		heading: 'Flexible and pragmatic',
		description:
			'He focuses on what matters most to each party, adapting the process to fit — including in-person, virtual, or hybrid formats.',
	},
	{
		heading: 'Calm and trust-building',
		description:
			'A structured, confidential process that helps parties reach resolution while preserving relationships where possible.',
	},
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Buxton Mediation | Peter Buxton KC, Mediator &amp; Arbitrator</title>
		<meta
			name="description"
			content="Peter Buxton KC offers mediation, arbitration, and Med-Arb services to clients across the Lower Mainland, BC. Process driven solutions to complex disputes."
		/>
	</head>
	<body class="bg-tan-05 font-sans text-navy antialiased scroll-smooth">
		<!-- Header / Nav -->
		<header class="sticky top-0 z-50 overflow-visible border-b border-tan-60 bg-tan-05/95 backdrop-blur">
			<nav class="mx-auto flex max-w-6xl min-h-[80px] flex-wrap items-center justify-between gap-3 overflow-visible px-4 py-2 sm:px-6 md:min-h-[112.5px]">
				<a href="#home" class="flex items-center overflow-visible">
					<img
						src="/buxton-adr-logo.svg"
						alt="Buxton ADR"
						class="h-auto w-[160px] overflow-visible sm:w-[200px] md:w-[280px]"
					/>
				</a>

				<!-- Mobile menu toggle -->
				<input type="checkbox" id="nav-toggle" class="peer hidden" />
				<label
					for="nav-toggle"
					aria-label="Toggle navigation menu"
					class="flex h-10 w-10 flex-shrink-0 cursor-pointer items-center justify-center md:hidden"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</label>

				<ul class="hidden w-full flex-col gap-x-6 gap-y-4 border-t border-tan-60 pt-4 font-alt text-sm font-medium uppercase tracking-[0.04em] text-navy/70 peer-checked:flex md:flex md:w-auto md:flex-row md:items-center md:border-0 md:pt-0">
					{navLinks.map((link) => (
						<li>
							<a href={link.href} class="block transition-colors hover:text-satsuma">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</nav>
			<div class="h-[2px] w-full bg-accent"></div>
		</header>

		<main>
			<!-- Hero -->
			<section id="home" class="flex flex-wrap bg-navy text-center text-white">
				<div class="flex flex-1 basis-full items-center justify-center px-6 py-20 lg:basis-1/2 lg:justify-end lg:py-28">
					<div class="max-w-md lg:pr-12">
						<h1 class="font-alt text-4xl font-medium uppercase leading-[1.05] tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
							Peter<br />Buxton<span class="tracking-normal">,</span> KC
						</h1>
						<p class="mt-3 font-alt text-xl tracking-wide sm:text-2xl">Mediator &amp; Arbitrator</p>
						<p class="mt-4 text-balance text-tan">
							Experienced. Neutral. Resolved.
						</p>
						<p class="mt-2 text-sm uppercase tracking-[0.2em] text-tan/70">
							Lower Mainland, BC
						</p>
					</div>
				</div>
				<div class="basis-full lg:basis-1/2">
					<img
						src="/Peter_Image.jpg"
						alt="Peter Buxton"
						class="h-80 w-full object-cover sm:h-[28rem] lg:h-full lg:min-h-[28rem]"
					/>
				</div>
			</section>

			<!-- Intro -->
			<section class="bg-white">
				<div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
					<p class="font-alt text-xs font-semibold uppercase tracking-[0.25em] text-accent">
						About Peter
					</p>
					<p class="mt-3 font-alt text-xs font-semibold uppercase tracking-[0.15em] text-logo-navy">
						{['King\'s Counsel — 2015', 'Mediate BC Roster', 'Called to Bar — 1981'].map((item, i) => (
							<>
								{i > 0 && <span class="mx-2 text-accent">&middot;</span>}
								{item}
							</>
						))}
					</p>
					<h2 class="mt-3 font-alt text-3xl font-semibold tracking-[0.02em] sm:text-4xl">
						About Peter
					</h2>
					<hr class="my-5 h-[3px] w-[2.85em] border-0 bg-satsuma" />
					<div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
						<p class="text-navy/80">
							Called to the Bar in British Columbia in 1981, Peter Buxton spent
							over 40 years as a trial lawyer before turning his focus to
							mediation, arbitration, and Med-Arb.
						</p>
						<div class="space-y-4 text-navy/80">
							<p>
								Over four decades of practice, Peter appeared regularly in
								personal injury, criminal, family, estate, corporate, and labour
								matters — giving him a breadth of experience few neutrals can
								match. He was appointed King's Counsel in 2015 and is a rostered
								mediator with Mediate BC.
							</p>
							<p>
								He draws on this experience as a mediator and arbitrator to
								create and manage a process suited to the dispute at hand —
								including Med-Arb, where mediation and arbitration are combined
								into one. As a neutral, Peter brings even-handed and efficient
								management of procedural matters, and a high measure of care
								when helping parties reach a resolution.
							</p>
						</div>
					</div>

					<div class="mt-10 rounded-[0.625rem] bg-tan-40 p-8 sm:p-12">
						<div class="grid gap-10 sm:grid-cols-2">
							<div>
								<h3 class="font-alt text-base font-semibold uppercase tracking-[0.1em]">Background</h3>
								<ul class="mt-3 space-y-1 text-sm leading-relaxed text-navy/80">
									<li><span class="font-semibold">1981</span> — Called to the Bar in British Columbia</li>
									<li>40+ years as a trial lawyer</li>
									<li>Personal injury, criminal, family, estate, corporate, and labour law</li>
									<li><span class="font-semibold">2015</span> — Appointed King's Counsel</li>
								</ul>
							</div>
							<div>
								<h3 class="font-alt text-base font-semibold uppercase tracking-[0.1em]">Designations</h3>
								<ul class="mt-3 space-y-1 text-sm leading-relaxed text-navy/80">
									<li>King's Counsel (KC), 2015</li>
									<li>Rostered Mediator, Mediate BC</li>
									<li>Mediation, Arbitration &amp; Med-Arb practice</li>
								</ul>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Practice area sections: Med-Arb, Mediation, Arbitration -->
			{practiceAreas.map((area) => (
				<section id={area.id} class={`page-section ${area.id === 'mediation' ? 'bg-white' : 'bg-cream'}`}>
					<div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
						<div class="max-w-3xl">
							{area.eyebrow && (
								<p class="font-alt text-xs font-semibold uppercase tracking-[0.25em] text-satsuma">
									{area.eyebrow}
								</p>
							)}
							<h2 class="mt-3 font-alt text-3xl font-semibold tracking-[0.02em] sm:text-4xl">
								{area.title}
							</h2>
							<hr class="my-5 h-[3px] w-[2.85em] border-0 bg-satsuma" />
							<p class="max-w-prose text-balance text-lg text-navy/80">{area.intro}</p>
						</div>
						<ul class="mt-10 grid gap-x-10 gap-y-3 text-navy/80 sm:grid-cols-2">
							{area.items.map((item) => (
								<li class="flex gap-3 border-t border-tan-60 py-3">
									<span class="font-alt text-satsuma">+</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
				</section>
			))}

			<!-- About -->
			<section id="about" class="page-section bg-white">
				<div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
					<div class="max-w-3xl">
						<p class="font-alt text-xs font-semibold uppercase tracking-[0.25em] text-accent">
							Approach
						</p>
						<h2 class="mt-3 font-alt text-3xl font-semibold tracking-[0.02em] sm:text-4xl">Approach</h2>
						<hr class="my-5 h-[3px] w-[2.85em] border-0 bg-satsuma" />
					</div>
					<div class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
						{approach.map((item) => (
							<div>
								<h3 class="font-alt text-lg font-semibold tracking-wide">{item.heading}</h3>
								<p class="mt-2 text-sm leading-relaxed text-navy/80">{item.description}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Fees -->
			<section id="fees" class="page-section bg-cream">
				<div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
					<div class="max-w-3xl">
						<p class="font-alt text-xs font-semibold uppercase tracking-[0.25em] text-accent">
							Fees
						</p>
						<h2 class="mt-3 font-alt text-3xl font-semibold tracking-[0.02em] sm:text-4xl">Format &amp; Fees</h2>
						<hr class="my-5 h-[3px] w-[2.85em] border-0 bg-satsuma" />
						<p class="max-w-prose text-balance text-lg text-navy/80">
							Available in-person, virtual, or hybrid. Fees are charged on a
							flexible, hourly basis according to the number of parties and
							the complexity of the dispute.
						</p>
					</div>
				</div>
			</section>

			<!-- Booking -->
			<section id="booking" class="page-section bg-white">
				<div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
					<div class="max-w-3xl">
						<p class="font-alt text-xs font-semibold uppercase tracking-[0.25em] text-accent">
							Availability
						</p>
						<h2 class="mt-3 font-alt text-3xl font-semibold tracking-[0.02em] sm:text-4xl">Check Availability</h2>
						<hr class="my-5 h-[3px] w-[2.85em] border-0 bg-satsuma" />
						<p class="max-w-prose text-balance text-lg text-navy/80">
							Review available dates below and submit a booking request. Peter will confirm your date directly.
						</p>
					</div>

					<div class="mt-10 grid gap-12 lg:grid-cols-2 lg:gap-16">

						<!-- Custom Mon–Fri calendar -->
						<div>
							<!-- Nav header -->
							<div class="mb-4 flex items-center justify-between">
								<button id="cal-prev" class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-navy/20 font-alt text-lg font-medium text-navy/60 transition-colors hover:border-accent hover:text-accent">&#8249;</button>
								<span id="cal-title" class="font-alt text-lg font-semibold tracking-wide text-navy"></span>
								<button id="cal-next" class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-navy/20 font-alt text-lg font-medium text-navy/60 transition-colors hover:border-accent hover:text-accent">&#8250;</button>
							</div>
							<!-- Day-of-week headers -->
							<div class="mb-1 grid grid-cols-5 gap-1">
								{['Mon','Tue','Wed','Thu','Fri'].map(d => (
									<div class="py-2 text-center font-alt text-xs font-semibold uppercase tracking-wider text-navy/40">{d}</div>
								))}
							</div>
							<!-- Grid (populated by JS) -->
							<div id="cal-grid"></div>
							<!-- Legend -->
							<div class="mt-5 flex flex-wrap gap-6 text-sm text-navy/80">
								<div class="flex items-center gap-2">
									<span class="inline-block h-3 w-3 rounded-full" style="background:#23364c;"></span>
									<span>Booked</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="inline-block h-3 w-3 rounded-full" style="background:#E8652A;"></span>
									<span>On Hold</span>
								</div>
							</div>
						</div>

						<!-- Booking request form -->
						<div>
							<h3 class="font-alt text-lg font-semibold tracking-wide">Booking Request</h3>
							<p class="mt-1 text-sm text-navy/60">Submit your preferred date and we'll confirm availability.</p>

							<form
								id="booking-form"
								action="https://formspree.io/f/xpqgqygw"
								method="POST"
								class="mt-6 grid gap-6"
							>
								<div class="grid gap-6 sm:grid-cols-2">
									<div>
										<label for="full-name" class="block text-sm text-navy/60">Full Name <span class="text-accent">*</span></label>
										<input
											type="text"
											id="full-name"
											name="full_name"
											required
											class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy placeholder-navy/30 focus:border-accent focus:outline-none focus:ring-0"
										/>
									</div>
									<div>
										<label for="book-email" class="block text-sm text-navy/60">Email <span class="text-accent">*</span></label>
										<input
											type="email"
											id="book-email"
											name="email"
											required
											class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy placeholder-navy/30 focus:border-accent focus:outline-none focus:ring-0"
										/>
									</div>
								</div>
								<div class="grid gap-6 sm:grid-cols-2">
									<div>
										<label for="telephone" class="block text-sm text-navy/60">Telephone Number <span class="text-accent">*</span></label>
										<input
											type="tel"
											id="telephone"
											name="telephone"
											required
											class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy placeholder-navy/30 focus:border-accent focus:outline-none focus:ring-0"
										/>
									</div>
									<div>
										<label for="firm" class="block text-sm text-navy/60">Firm / Organization</label>
										<input
											type="text"
											id="firm"
											name="firm"
											class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy placeholder-navy/30 focus:border-accent focus:outline-none focus:ring-0"
										/>
									</div>
								</div>
								<div class="grid gap-6 sm:grid-cols-2">
									<div>
										<label for="requested-date" class="block text-sm text-navy/60">Requested Date <span class="text-accent">*</span></label>
										<input
											type="date"
											id="requested-date"
											name="requested_date"
											required
											class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy focus:border-accent focus:outline-none focus:ring-0"
										/>
									</div>
									<div>
										<label for="style-of-cause" class="block text-sm text-navy/60">Full Style of Cause <span class="text-accent">*</span></label>
										<input
											type="text"
											id="style-of-cause"
											name="style_of_cause"
											required
											class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy placeholder-navy/30 focus:border-accent focus:outline-none focus:ring-0"
										/>
									</div>
								</div>
								<div>
									<label for="notes" class="block text-sm text-navy/60">Notes</label>
									<textarea
										id="notes"
										name="notes"
										rows="4"
										placeholder="Any additional information about your mediation request"
										class="mt-2 block w-full border-0 border-b border-navy/25 bg-transparent px-0 py-2 text-navy placeholder-navy/30 focus:border-accent focus:outline-none focus:ring-0"
									></textarea>
								</div>
								<input type="hidden" name="_subject" value="New Booking Request — Buxton ADR" />
								<button
									type="submit"
									class="w-fit rounded-[5px] bg-logo-navy px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent"
								>
									Submit Request
								</button>
							</form>

							<!-- Success message (hidden by default) -->
							<div id="booking-success" class="hidden mt-6 rounded-[0.625rem] border border-navy/20 bg-cream p-6">
								<p class="font-alt text-base font-semibold text-navy">Request received.</p>
								<p class="mt-1 text-sm text-navy/80">Thank you — Peter will be in touch shortly to confirm your date.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Contact -->
			<section id="contact" class="page-section bg-navy text-white">
				<div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
					<div class="max-w-2xl">
						<h2 class="font-alt text-3xl font-semibold tracking-[0.02em] sm:text-4xl">Contact</h2>
						<hr class="my-5 h-[3px] w-[2.85em] border-0 bg-satsuma" />
						<p class="text-lg text-tan">
							Ready to discuss your dispute or schedule a consultation? Send a
							message below and you'll hear back shortly.
						</p>
					</div>
					<form class="mt-10 grid max-w-xl gap-6">
						<div class="grid gap-6 sm:grid-cols-2">
							<div>
								<label for="name" class="block text-sm text-tan">Name</label>
								<input
									type="text"
									id="name"
									name="name"
									class="mt-2 block w-full border-0 border-b border-white/30 bg-transparent px-0 py-2 text-white placeholder-white/40 focus:border-satsuma focus:outline-none focus:ring-0"
								/>
							</div>
							<div>
								<label for="email" class="block text-sm text-tan">Email</label>
								<input
									type="email"
									id="email"
									name="email"
									class="mt-2 block w-full border-0 border-b border-white/30 bg-transparent px-0 py-2 text-white placeholder-white/40 focus:border-satsuma focus:outline-none focus:ring-0"
								/>
							</div>
						</div>
						<div>
							<label for="message" class="block text-sm text-tan">Message</label>
							<textarea
								id="message"
								name="message"
								rows="5"
								class="mt-2 block w-full border-0 border-b border-white/30 bg-transparent px-0 py-2 text-white placeholder-white/40 focus:border-satsuma focus:outline-none focus:ring-0"
							></textarea>
						</div>
						<button
							type="submit"
							class="w-fit rounded-[5px] bg-satsuma px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white hover:text-navy"
						>
							Send message
						</button>
					</form>
				</div>
			</section>
		</main>

		<footer class="bg-tan-05">
			<div class="mx-auto max-w-6xl px-6 py-8">
				<p class="text-sm text-navy/50">
					&copy; {new Date().getFullYear()} Buxton Mediation.
				</p>
			</div>
		</footer>

		<script is:inline>
		(function () {
			var eventMap = {};
			var MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
			var today = new Date();
			var year = today.getFullYear();
			var month = today.getMonth();

			function pad(n) { return String(n).padStart(2, '0'); }
			function ds(y, m, d) { return y + '-' + pad(m + 1) + '-' + pad(d); }

			function parseIcs(raw) {
				var text = raw.replace(/\r\n[ \t]/g, '').replace(/\r\n/g, '\n').replace(/\r/g, '\n');
				var map = {};
				text.split(/BEGIN:VEVENT/).slice(1).forEach(function(block) {
					var summaryM = block.match(/^SUMMARY:(.+)$/m);
					var startM   = block.match(/^DTSTART[^:\r\n]*:(\d{8})/m);
					var endM     = block.match(/^DTEND[^:\r\n]*:(\d{8})/m);
					if (!startM) return;
					var summary = ((summaryM && summaryM[1]) || '').trim().toLowerCase();
					var type = summary.indexOf('hold') !== -1 ? 'on-hold' : 'booked';
					function toD(s) { return new Date(+s.slice(0,4), +s.slice(4,6)-1, +s.slice(6,8)); }
					var start = toD(startM[1]);
					var end = new Date(start.getTime() + 86400000);
					if (endM) { var e = toD(endM[1]); if (e > start) end = e; }
					for (var cur = new Date(start); cur < end; cur = new Date(cur.getTime() + 86400000)) {
						var dow = cur.getDay();
						if (dow >= 1 && dow <= 5) {
							map[cur.getFullYear() + '-' + pad(cur.getMonth()+1) + '-' + pad(cur.getDate())] = type;
						}
					}
				});
				return map;
			}

			function buildWeeks(y, m) {
				var days = new Date(y, m + 1, 0).getDate();
				var weeks = [], week = [null,null,null,null,null], lastCol = -1;
				for (var d = 1; d <= days; d++) {
					var dow = new Date(y, m, d).getDay();
					if (dow === 0 || dow === 6) continue;
					var col = dow - 1;
					if (lastCol !== -1 && col <= lastCol) { weeks.push(week); week = [null,null,null,null,null]; }
					week[col] = d;
					lastCol = col;
				}
				if (week.some(function(x) { return x !== null; })) weeks.push(week);
				return weeks;
			}

			function render() {
				var title = document.getElementById('cal-title');
				var grid = document.getElementById('cal-grid');
				if (!title || !grid) return;
				title.textContent = MONTHS[month] + ' ' + year;
				var todayStr = ds(today.getFullYear(), today.getMonth(), today.getDate());
				var html = '';
				buildWeeks(year, month).forEach(function(week) {
					html += '<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:4px;margin-bottom:4px;">';
					week.forEach(function(d) {
						if (d === null) { html += '<div></div>'; return; }
						var dateStr = ds(year, month, d);
						var type = eventMap[dateStr];
						var isPast = dateStr < todayStr;
						var isToday = dateStr === todayStr;
						var bg, color, weight, opacity;
						if (type === 'booked')       { bg = '#23364c'; color = '#fff'; weight = '600'; opacity = isPast ? '0.45' : '1'; }
						else if (type === 'on-hold') { bg = '#E8652A'; color = '#fff'; weight = '600'; opacity = isPast ? '0.45' : '1'; }
						else { bg = '#fafafa'; color = isPast ? '#bbb' : '#23364c'; weight = '400'; opacity = '1'; }
						var border = isToday ? '2px solid #E8652A' : '1px solid #e8e3dd';
						html += '<div style="background:' + bg + ';color:' + color + ';font-weight:' + weight + ';opacity:' + opacity + ';border:' + border + ';border-radius:5px;padding:10px 4px;text-align:center;font-size:0.875rem;">' + d + '</div>';
					});
					html += '</div>';
				});
				grid.innerHTML = html;
			}

			// Show loading state, fetch live events, then render
			var grid = document.getElementById('cal-grid');
			if (grid) grid.innerHTML = '<p style="color:#23364c;opacity:0.5;font-size:0.875rem;padding:1rem 0;">Loading availability…</p>';
			render(); // render empty calendar immediately so nav/headers show

			fetch('/api/calendar')
				.then(function(r) { return r.ok ? r.text() : Promise.reject(r.status); })
				.then(function(ics) { eventMap = parseIcs(ics); render(); })
				.catch(function() { render(); }); // render without events on error

			var prev = document.getElementById('cal-prev');
			var next = document.getElementById('cal-next');
			if (prev) prev.addEventListener('click', function() { month--; if (month < 0) { month = 11; year--; } render(); });
			if (next) next.addEventListener('click', function() { month++; if (month > 11) { month = 0; year++; } render(); });
		})();
		</script>

		<script>
			const form = document.getElementById('booking-form') as HTMLFormElement | null;
			const success = document.getElementById('booking-success');
			if (form && success) {
				form.addEventListener('submit', async (e) => {
					e.preventDefault();
					const data = new FormData(form);
					const res = await fetch(form.action, {
						method: 'POST',
						body: data,
						headers: { Accept: 'application/json' },
					});
					if (res.ok) {
						form.classList.add('hidden');
						success.classList.remove('hidden');
					} else {
						alert('Something went wrong — please try again or email info@pacifictelecomconsulting.com directly.');
					}
				});
			}
		</script>
	</body>
</html>
